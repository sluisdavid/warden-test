# Copy this file to .env for local overrides.
# Docker Compose reads .env automatically.

WARDEN_DATABASE_URL=/data/warden.db
WARDEN_HISTORY_LIMIT=5
WARDEN_LLM_PROVIDER=heuristic
WARDEN_LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
WARDEN_LLM_API_KEY=
WARDEN_LLM_MODEL=llama-3.1-8b-instant
WARDEN_ORCHESTRATOR_BASE_URL=http://orchestrator-mock:8001
WARDEN_NOTIFIER_BASE_URL=http://notifier-mock:8002
WARDEN_LOG_LEVEL=INFO
